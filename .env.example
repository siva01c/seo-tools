# Copy this file to .env and fill in your values:  cp .env.example .env

# ─── Crawler target settings ──────────────────────────────────────────────────

# Start URL (the site to crawl). Used as the default target when no URL is passed
# on the command line. The CLI argument (e.g. `make crawl ARGS="https://..."`)
# always takes precedence over this.
CRAWLER_START_URLS=https://example.com

# Allowed domains — comma-separated list of domains the crawler may follow.
# If empty, defaults to the hostname of CRAWLER_START_URLS.
CRAWLER_ALLOWED_DOMAINS=example.com,www.example.com

# Domains to exclude — subdomains/domains to never crawl (comma-separated)
CRAWLER_EXCLUDED_DOMAINS=api.example.com,cdn.example.com

# URL paths to exclude — comma-separated list of path prefixes to skip
CRAWLER_EXCLUDED_PATHS=/wp-admin,/user/login,/cart,/checkout

# Enable sitemap discovery (true/false)
CRAWLER_SITEMAP_DISCOVERY=true

# Respect robots.txt Disallow rules (true/false). Enabled by default; disable only for
# authorized/internal crawls where you explicitly want to ignore robots.txt.
# The `--ignore-robots` CLI flag does the same for a single run.
CRAWLER_RESPECT_ROBOTS_TXT=true

# Optional single-URL override (alias used by some Docker examples). When set,
# the crawler targets exactly this URL. Prefer CRAWLER_START_URLS above for
# normal use; this exists for `docker compose`/scripted single-page runs.
# START_URL=https://example.com

# ─── MCP server (optional) ────────────────────────────────────────────────────
# Only needed if you run the `mcp` service (docker compose up mcp).

# Token required to authenticate requests to the MCP endpoint (/mcp/post).
# Accepted as "Authorization: Basic <base64(token)>" or "Authorization: Bearer <token>".
# REQUIRED in production: the server refuses to start with NODE_ENV=production
# and no token. A valid token also bypasses the /api/crawl rate limit.
# Generate one with:  openssl rand -hex 24
SEO_MCP_TOKEN=

# Port the MCP server listens on (defaults to 3001 if unset)
MCP_PORT=3001

# Origins allowed to call the HTTP API cross-origin (comma-separated).
# Empty (default) = no CORS headers, same-origin browsers only.
# SEO_CORS_ORIGINS=https://seo.mcpserver.cz

# Max crawl jobs running at once; further requests get HTTP 429 (default 2)
# SEO_MAX_CONCURRENT_CRAWLS=2

# Max POST /api/crawl requests per client IP per hour (default 5)
# SEO_CRAWL_RATE_LIMIT=5

# Max GET /api/crawl/status/:id and /api/crawl/report/:id requests per client IP per hour
# (default 120). Looser than SEO_CRAWL_RATE_LIMIT since legitimate clients poll status
# frequently; exists to bound job-ID scraping/enumeration, not normal polling.
# SEO_CRAWL_READ_RATE_LIMIT=120

# Max report emails sent to a given address per day (default 5). Prevents /api/crawl's
# email-a-report flow from being used as an open spam vector.
# SEO_EMAIL_RATE_LIMIT=5

# Max pages crawled per unauthenticated POST /api/crawl request (default 50).
# A valid SEO_MCP_TOKEN bypasses this cap. See docs/security.md for the rationale
# (accepted-risk mitigation in place of domain-ownership verification).
# SEO_PUBLIC_CRAWL_MAX_REQUESTS=50

# Wall-clock timeout (ms) before a crawl child process is killed (default 900000 = 15 min)
# SEO_CRAWL_TIMEOUT_MS=900000

# ─── Mail API Configuration ───────────────────────────────────────────────────
MAIL_API_URL=http://sales-assistant-assistant-1:8000/api/mail/send
MAIL_API_TOKEN=change-me-mail-token
SMTP_FROM=seo@ludekkvapil.cz

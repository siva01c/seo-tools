# Copy this file to .env and fill in your values:  cp .env.example .env

# ─── Crawler target settings ──────────────────────────────────────────────────

# Start URL (the site to crawl). Used as the default target when no URL is passed
# on the command line. The CLI argument (e.g. `make crawl ARGS="https://..."`)
# always takes precedence over this.
CRAWLER_START_URLS=https://example.com

# Allowed domains — comma-separated list of domains the crawler may follow.
# If empty, defaults to the hostname of CRAWLER_START_URLS.
CRAWLER_ALLOWED_DOMAINS=example.com,www.example.com

# Domains to exclude — subdomains/domains to never crawl (comma-separated)
CRAWLER_EXCLUDED_DOMAINS=api.example.com,cdn.example.com

# URL paths to exclude — comma-separated list of path prefixes to skip
CRAWLER_EXCLUDED_PATHS=/wp-admin,/user/login,/cart,/checkout

# Enable sitemap discovery (true/false)
CRAWLER_SITEMAP_DISCOVERY=true

# Optional single-URL override (alias used by some Docker examples). When set,
# the crawler targets exactly this URL. Prefer CRAWLER_START_URLS above for
# normal use; this exists for `docker compose`/scripted single-page runs.
# START_URL=https://example.com

# ─── MCP server (optional) ────────────────────────────────────────────────────
# Only needed if you run the `mcp` service (docker compose up mcp).

# Bearer token required to authenticate requests to the MCP server.
# Generate one with:  openssl rand -hex 24
SEO_MCP_TOKEN=

# Port the MCP server listens on (defaults to 3001 if unset)
MCP_PORT=3001

# ─── Mail API Configuration ───────────────────────────────────────────────────
MAIL_API_URL=http://sales-assistant-assistant-1:8000/api/mail/send
MAIL_API_TOKEN=change-me-mail-token
SMTP_FROM=seo@ludekkvapil.cz
